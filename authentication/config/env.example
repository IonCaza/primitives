# Authentication Primitive - Required Environment Variables

# Used to derive Fernet encryption key for all credential vaulting
# (TOTP secrets, OIDC client secrets, platform tokens, SSH keys, SMTP passwords)
SECRET_KEY=change-me-to-a-strong-random-value

# JWT token signing secret
JWT_SECRET=change-me-to-a-different-strong-random-value

# JWT token expiration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL database URL (async driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myapp

# Redis URL (for OIDC state, email OTP storage/cooldown)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (used for OIDC callback redirect)
FRONTEND_URL=http://localhost:3000

# Backend URL (used for OIDC callback URL construction)
BACKEND_URL=http://localhost:8000
