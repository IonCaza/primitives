# Agentic AI Engine - Required environment variables

# Secret key for Fernet encryption of LLM provider API keys
# Must be consistent across restarts (keys become unreadable if changed)
SECRET_KEY=your-secret-key-here

# Database URL (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myapp

# Optional: Redis URL (for future caching/pub-sub features)
# REDIS_URL=redis://localhost:6379

# LLM provider API keys are stored encrypted in the database,
# managed through the admin UI. No env-level API keys needed.
